# Copy to .env and fill in your values
# NEVER commit .env to git

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
# Create the database first: createdb helixa
DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/helixa

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=90d41f3efd9ea6bb4d415249730cf12679ac1e7793445c33346cd8a6bc92a111
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── AI: Groq (free tier — no credit card required) ──────────────────────────
# Sign up at https://console.groq.com → API Keys → Create Key
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-specdec
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant

# ─── AI: Ollama (local fallback) ─────────────────────────────────────────────
# Ensure Ollama is running: ollama serve
# Pull models: ollama pull llama3.1:8b && ollama pull meditron:7b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_MEDICAL_MODEL=meditron:7b

# ─── File Storage ─────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=20

# ─── Vector DB (Qdrant local — no Docker required) ────────────────────────────
QDRANT_PATH=./qdrant_storage
QDRANT_COLLECTION=medical_knowledge
EMBEDDING_MODEL=NeuML/pubmedbert-base-embeddings

# ─── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
